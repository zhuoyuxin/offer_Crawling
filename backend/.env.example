# ============================================
#  Jobs Tracker 后端 - 环境变量配置样例
#  复制本文件为 .env 后填入真实值
#  cp .env.example .env
# ============================================

# 运行环境：设为 production 时，必须配置 PEPPER，否则拒绝启动
NODE_ENV=production

# ── 安全密钥（必填） ──────────────────────────
# 用于 token / 指纹哈希的加盐值，每个项目应唯一
# 生成方式：openssl rand -base64 32
TOKEN_PEPPER=
FINGERPRINT_PEPPER=

# ── 初始管理员账号（首次启动自动创建，建成后可删除这两行） ──
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── 服务配置 ──────────────────────────────────
PORT=3001

# 允许的前端来源，多个用逗号分隔
# 示例：https://example.com,https://www.example.com
CORS_ORIGIN=http://localhost:5173

# 如果后端部署在 Nginx / Caddy 等反向代理之后，设为 true
TRUST_PROXY=false

# ── 数据库 ────────────────────────────────────
# 默认为项目下 data/jobs.db，部署时建议指定绝对路径
# DB_PATH=/var/lib/jobs-tracker/jobs.db

# ── 可选调优（以下均有合理默认值） ────────────
# 会话有效期（秒），默认 10800（3小时）
# SESSION_TTL_SECONDS=10800

# bcrypt 加密轮数，默认 12
# BCRYPT_ROUNDS=12

# 登录限速：窗口时间（分钟） / 最大次数
# LOGIN_RATE_WINDOW_MIN=15
# LOGIN_RATE_MAX=10

# 注册限速：窗口时间（分钟） / 最大次数
# REGISTER_RATE_WINDOW_MIN=60
# REGISTER_RATE_MAX=5
